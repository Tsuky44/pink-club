{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/admin/events/[eventId]",
      "regex": "^/api/admin/events/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPeventId": "nxtPeventId"
      },
      "namedRegex": "^/api/admin/events/(?<nxtPeventId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/admin/users/[userId]",
      "regex": "^/api/admin/users/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPuserId": "nxtPuserId"
      },
      "namedRegex": "^/api/admin/users/(?<nxtPuserId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/auth/[...nextauth]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPnextauth": "nxtPnextauth"
      },
      "namedRegex": "^/api/auth/(?<nxtPnextauth>.+?)(?:/)?$"
    },
    {
      "page": "/api/kudos/[photoId]",
      "regex": "^/api/kudos/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPphotoId": "nxtPphotoId"
      },
      "namedRegex": "^/api/kudos/(?<nxtPphotoId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/photos/[id]",
      "regex": "^/api/photos/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/photos/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/uploads/[...path]",
      "regex": "^/api/uploads/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPpath": "nxtPpath"
      },
      "namedRegex": "^/api/uploads/(?<nxtPpath>.+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/admin",
      "regex": "^/admin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin(?:/)?$"
    },
    {
      "page": "/api/admin/events",
      "regex": "^/api/admin/events(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/admin/events(?:/)?$"
    },
    {
      "page": "/api/photos",
      "regex": "^/api/photos(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/photos(?:/)?$"
    },
    {
      "page": "/api/photos/top",
      "regex": "^/api/photos/top(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/photos/top(?:/)?$"
    },
    {
      "page": "/api/rsvp",
      "regex": "^/api/rsvp(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/rsvp(?:/)?$"
    },
    {
      "page": "/auth/login",
      "regex": "^/auth/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/auth/login(?:/)?$"
    },
    {
      "page": "/bientot-disponible",
      "regex": "^/bientot\\-disponible(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/bientot\\-disponible(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/flotte",
      "regex": "^/flotte(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/flotte(?:/)?$"
    },
    {
      "page": "/wall-of-fame",
      "regex": "^/wall\\-of\\-fame(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/wall\\-of\\-fame(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}